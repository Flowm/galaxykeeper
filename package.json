{
  "name": "galaxy-keeper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:viewer": "vite build --config vite.viewer.config.ts",
    "predev": "pnpm run build:viewer",
    "dev": "vite",
    "prebuild": "pnpm run build:viewer",
    "build": "vite build",
    "preview": "vite preview",
    "pretest": "pnpm run build:viewer",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit && vue-tsc --noEmit -p viewer/tsconfig.json",
    "lint": "pnpm lint:web && pnpm lint:worker",
    "lint:web": "oxlint && oxfmt --check && vue-tsc && vue-tsc -p viewer/tsconfig.json",
    "lint:worker": "pnpm --filter galaxy-keeper-worker lint",
    "lint:fix": "pnpm lint:fix:web && pnpm lint:fix:worker",
    "lint:fix:web": "oxlint --fix && oxfmt --write",
    "lint:fix:worker": "pnpm --filter galaxy-keeper-worker lint:fix",
    "dev:worker": "pnpm --filter galaxy-keeper-worker dev",
    "deploy": "pnpm build && pnpm --filter galaxy-keeper-worker deploy",
    "deploy:preview": "pnpm build && pnpm --filter galaxy-keeper-worker deploy:preview"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "three": "^0.185.1",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/three": "^0.185.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "tailwindcss": "^4.3.2",
    "typescript": "catalog:",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "packageManager": "pnpm@11.9.0"
}
