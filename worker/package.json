{
  "name": "galaxy-keeper-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deploy": "wrangler deploy",
    "deploy:preview": "wrangler versions upload --preview-alias preview-$(git rev-parse --short=8 HEAD)",
    "dev": "wrangler dev --port 8787",
    "lint": "oxlint && oxfmt --check && tsc --noEmit",
    "lint:fix": "oxlint --fix && oxfmt --write",
    "generate-types": "wrangler types src/worker-configuration.d.ts",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "wrangler": "^4.112.0"
  }
}
