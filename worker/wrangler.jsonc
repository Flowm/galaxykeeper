{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "galaxykeeper",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-10",
  "send_metrics": false,
  "routes": [
    {
      "pattern": "galaxykeeper.frcy.org",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "../dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/proxy"],
  },
  "observability": {
    "enabled": true,
  },
}
